# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# JSON
*.json text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.bdf binary
*.pyc binary
*.so binary
